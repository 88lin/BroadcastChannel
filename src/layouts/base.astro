---
import '../styles/app.css'
import { SEO } from 'astro-seo'
import { getEnv } from '../lib/env'
import { Icon } from 'astro-icon/components'
import backToTopIcon from '../assets/back-to-top.svg'
import voidFile from '../assets/void.png'
import { siteTitleStyle } from '../lib/ui'
import type { NavItem } from '../types'

const { SITE_URL, RSS_URL, RSS_PREFIX } = Astro.locals
const { channel } = Astro.props

const localeEnv = getEnv(import.meta.env, Astro, 'LOCALE')
const locale = typeof localeEnv === 'string' ? localeEnv : undefined

const seo = channel?.seo

function normalizePathname(pathname: string): string {
  return pathname.replace(/\/$/, '') || '/'
}

function toSiteAssetUrl(value: string | undefined): string | undefined {
  if (!value) {
    return undefined
  }

  return value.startsWith('http') ? value : new URL(value, absoluteSiteUrl).toString()
}

const absoluteSiteUrl = SITE_URL.startsWith('http') ? SITE_URL : new URL(SITE_URL, Astro.url.origin).toString()
const canonicalUrl = new URL(Astro.url.pathname, absoluteSiteUrl)
const siteRootPathname = normalizePathname(new URL(absoluteSiteUrl).pathname)
const canonical =
  normalizePathname(canonicalUrl.pathname) === siteRootPathname
    ? canonicalUrl.toString()
    : canonicalUrl.toString().replace(/\/$/, '')

const { pathname } = new URL(canonical)
const currentPathname = normalizePathname(pathname)
const twitterEnv = getEnv(import.meta.env, Astro, 'TWITTER')
const twitter = typeof twitterEnv === 'string' ? twitterEnv : undefined
const staticProxy = getEnv(import.meta.env, Astro, 'STATIC_PROXY') ?? '/static/'
const pageTitle = seo?.title?.trim()
const siteTitle = channel?.title ?? ''
const seoDescription = seo?.text ?? channel?.description
const avatarUrl = channel?.avatarNeedsProxy
  ? channel.avatar?.startsWith('http')
    ? `${staticProxy}${channel.avatar}`
    : undefined
  : toSiteAssetUrl(channel?.avatar)
const avatarImageSource = channel?.avatarNeedsProxy ? channel.avatar : toSiteAssetUrl(channel?.avatar)
const shareImage = avatarImageSource?.startsWith('http')
  ? channel?.avatarNeedsProxy
    ? `https://wsrv.nl/?w=1200&h=630&fit=cover&url=ssl:${avatarImageSource.replace(/^https?:\/\//, '')}`
    : avatarImageSource
  : new URL('favicon.ico', absoluteSiteUrl).toString()
const favicon = avatarImageSource?.startsWith('http')
  ? channel?.avatarNeedsProxy
    ? `https://wsrv.nl/?w=64&h=64&fit=cover&mask=circle&url=ssl:${avatarImageSource.replace(/^https?:\/\//, '')}`
    : avatarImageSource
  : new URL('favicon.svg', absoluteSiteUrl).toString()
const hasCustomTitle = Boolean(pageTitle && pageTitle !== siteTitle)
const isArticle = /\/posts\/[^/]+$/.test(pathname)
const tagsPathname = normalizePathname(new URL('tags', absoluteSiteUrl).pathname)
const linksPathname = normalizePathname(new URL('links', absoluteSiteUrl).pathname)

const seoParams = {
  title: pageTitle,
  description: seoDescription,
  canonical,
  noindex: seo?.noindex ?? getEnv(import.meta.env, Astro, 'NOINDEX'),
  nofollow: seo?.nofollow ?? getEnv(import.meta.env, Astro, 'NOFOLLOW'),
  openGraph: {
    basic: {
      type: isArticle ? 'article' : 'website',
      title: pageTitle ?? siteTitle,
      url: canonical,
      image: shareImage,
    },
    optional: {
      description: seoDescription,
      locale,
    },
  },
  extend: {
    link: [
      {
        rel: 'icon',
        href: favicon,
      },
      {
        rel: 'apple-touch-icon',
        href: new URL('favicon.ico', absoluteSiteUrl).toString(),
      },
      {
        rel: 'manifest',
        href: new URL('site.webmanifest', absoluteSiteUrl).toString(),
      },
    ],
  },
}

const googleSearchSiteEnv = getEnv(import.meta.env, Astro, 'GOOGLE_SEARCH_SITE')
const GOOGLE_SEARCH_SITE = typeof googleSearchSiteEnv === 'string' ? googleSearchSiteEnv : undefined
const searchAction = GOOGLE_SEARCH_SITE ? 'https://www.google.com/search' : `${SITE_URL}search/result`
const PODCASRT = getEnv(import.meta.env, Astro, 'PODCASRT')
const TWITTER = getEnv(import.meta.env, Astro, 'TWITTER')
const GITHUB = getEnv(import.meta.env, Astro, 'GITHUB')
const TELEGRAM = getEnv(import.meta.env, Astro, 'TELEGRAM')
const DISCORD = getEnv(import.meta.env, Astro, 'DISCORD')
const MASTODON = getEnv(import.meta.env, Astro, 'MASTODON')
const BLUESKY = getEnv(import.meta.env, Astro, 'BLUESKY')

const HEADER_INJECT = getEnv(import.meta.env, Astro, 'HEADER_INJECT')
const FOOTER_INJECT = getEnv(import.meta.env, Astro, 'FOOTER_INJECT')
const defaultBannerText =
  '请确保网络环境可正常访问订阅链接。部分链接需代理环境下导入，请自行筛选可用节点，可以点击评论区查看其中分享的节点是否可用！请勿相信网站中的任何广告！'
const SHOW_BANNER = getEnv(import.meta.env, Astro, 'SHOW_BANNER')
const bannerTextEnv = getEnv(import.meta.env, Astro, 'BANNER_TEXT')
const bannerText = typeof bannerTextEnv === 'string' ? bannerTextEnv.trim() : defaultBannerText
const showBanner = SHOW_BANNER !== false && Boolean(bannerText)
const TAGS = getEnv(import.meta.env, Astro, 'TAGS')
const LINKS = getEnv(import.meta.env, Astro, 'LINKS')
const navsEnv = getEnv(import.meta.env, Astro, 'NAVS')
const navs: NavItem[] = (typeof navsEnv === 'string' ? navsEnv : '')
  .split(';')
  .filter(Boolean)
  .map((link) => {
    const [title = '', href = ''] = link.split(',')
    return {
      title,
      href,
    }
  })
const socialLinks = [
  {
    href: RSS_URL,
    title: 'RSS Feed',
    label: 'RSS Feed',
    icon: 'ri:rss-line',
    rel: 'alternate noopener noreferrer',
    type: 'application/rss+xml',
  },
  PODCASRT && {
    href: PODCASRT,
    title: 'Podcast',
    label: 'Podcast',
    icon: 'ri:mic-line',
    rel: 'noopener noreferrer',
  },
  TWITTER &&
    TWITTER.length > 0 && {
      href: `https://x.com/${TWITTER}`,
      title: 'Twitter',
      label: 'Twitter / X',
      icon: 'ri:twitter-x-line',
      rel: 'noopener noreferrer',
    },
  GITHUB &&
    GITHUB.length > 0 && {
      href: `https://github.com/${GITHUB}`,
      title: 'GitHub',
      label: 'GitHub',
      icon: 'ri:github-line',
      rel: 'noopener noreferrer',
    },
  TELEGRAM &&
    TELEGRAM.length > 0 && {
      href: `https://t.me/${TELEGRAM}`,
      title: 'Telegram',
      label: 'Telegram',
      icon: 'ri:telegram-line',
      rel: 'noopener noreferrer',
    },
  DISCORD &&
    DISCORD.length > 0 && {
      href: DISCORD,
      title: 'Discord',
      label: 'Discord',
      icon: 'ri:discord-line',
      rel: 'noopener noreferrer',
    },
  MASTODON &&
    MASTODON.length > 0 && {
      href: `https://${MASTODON}`,
      title: 'Mastodon',
      label: 'Mastodon',
      icon: 'ri:mastodon-line',
      rel: 'noopener noreferrer',
    },
  BLUESKY &&
    BLUESKY.length > 0 && {
      href: `https://bsky.app/profile/${BLUESKY}`,
      title: 'BlueSky',
      label: 'Bluesky',
      icon: 'ri:bluesky-line',
      rel: 'noopener noreferrer',
    },
].filter(Boolean)

const layoutShellClass = 'mx-5'
const layoutGridClass = 'mx-auto flex w-full max-w-[920px] flex-col sm:items-start'
const mainPanelClass = 'w-full min-w-0 pb-5 pt-[10px] sm:flex-1 sm:pt-5'
const topNavWrapClass = `mx-3 pt-4 sm:mx-5 ${showBanner ? 'md:sticky md:top-4' : 'md:fixed md:left-0 md:right-0 md:top-4'} md:z-50 md:mx-auto md:px-5 md:pt-0`
const topNavClass =
  'site-top-nav mx-auto flex w-full max-w-[920px] min-w-0 flex-col gap-3 overflow-hidden rounded-[26px] px-3 py-3 sm:px-4 md:h-[52px] md:flex-row md:items-center md:justify-between md:gap-4 md:py-2 md:pl-4 md:pr-2'
const topNavBrandClass =
  'site-top-brand inline-flex max-w-full min-w-0 self-start items-center gap-2 rounded-full px-1.5 py-1 text-[15px] font-semibold leading-none text-heading no-underline hover:no-underline md:self-auto md:shrink-0'
const topNavLogoClass = 'h-7 w-7 shrink-0 rounded-full border border-line bg-code object-cover shadow-soft'
const topNavBrandTextClass = 'truncate'
const topNavGroupClass = 'flex w-full min-w-0 items-center gap-1.5 sm:justify-center md:w-auto md:flex-none'
const navListClass = 'm-0 flex min-w-0 list-none flex-wrap items-center gap-1.5 p-0 md:flex-nowrap md:gap-3'
const navItemClass = 'flex items-center text-[14px] leading-none'
const navLinkClass =
  'nav-btn inline-flex h-10 min-w-0 items-center justify-center rounded-full px-3 py-1 text-[14px] font-semibold tracking-[0.1em] text-heading no-underline transition-all duration-100 ease-in-out hover:no-underline active:translate-y-0 md:min-w-[76px]'
const navLinkCurrentClass = 'nav-btn--active font-medium'
const skipLinkClass =
  'pointer-events-none absolute left-5 top-0 z-[1100] -translate-y-full rounded-panel bg-heading px-3 py-2 text-sm text-white no-underline transition-transform duration-150 focus-visible:pointer-events-auto focus-visible:translate-y-5 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-heading'
const topNavActionClass = 'flex w-full min-w-0 flex-wrap items-center gap-2 sm:justify-end md:w-auto'
const socialNavClass = 'flex items-center gap-1'
const socialLinkClass =
  'group inline-flex h-8 w-8 items-center justify-center rounded-full border border-transparent text-muted no-underline transition duration-100 hover:border-[#93c5fd] hover:bg-[#ebf4ff] hover:text-[#1e73be] hover:no-underline'
const socialIconClass =
  'h-[1em] w-[1em] align-bottom [filter:var(--icon-secondary-filter)] group-hover:[filter:var(--icon-hover-filter)]'
const searchFormClass =
  'min-w-0 flex-1 rounded-full border border-[#bfdbfe]/70 bg-[#ebf4ff]/75 p-1 text-muted shadow-[inset_0_1px_0_rgba(255,255,255,0.72)] md:min-w-[110px] md:flex-none'
const searchInputClass =
  'box-border w-full rounded-full border border-transparent bg-transparent px-3 text-[15px] leading-[2.2] text-[#1e73be] outline-none placeholder:text-[#1e73be]/60 focus-visible:border-[#93c5fd] focus-visible:bg-white/70 focus-visible:outline focus-visible:outline-1 focus-visible:outline-offset-0 focus-visible:outline-[#93c5fd] md:w-[118px] md:text-[13px]'
const footerClass = 'text-[13px] leading-none text-footer'
const footerLinkClass =
  'inline-flex min-h-9 items-center rounded-full border border-[#93c5fd]/80 bg-[#ebf4ff]/80 px-4 font-medium text-[#1e73be] no-underline shadow-[inset_0_1px_0_rgba(255,255,255,0.72)] transition duration-100 hover:border-[#60a5fa] hover:bg-[#dbeafe] hover:text-[#155f9f] hover:no-underline'
const backToTopClass =
  'pointer-events-auto z-[1000] flex h-8 w-8 items-center justify-center rounded-full bg-code text-[24px] opacity-90 transition-transform duration-300 hover:-translate-y-[3px] active:translate-y-px'
const backToTopIconClass = 'h-auto w-auto [filter:var(--icon-secondary-filter)]'
const skipLinkText = 'Skip to main content'
const searchLabelText = 'Search'
---

<!doctype html>
<html lang={locale ?? 'en'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#fdfdf7" />
    <link rel="alternate" type="application/rss+xml" title={`${RSS_PREFIX}${channel?.title}`} href={RSS_URL} />
    <SEO
      titleTemplate={hasCustomTitle ? `%s | ${siteTitle}` : undefined}
      titleDefault={siteTitle || seoParams.description}
      twitter={{
        card: 'summary_large_image',
        creator: twitter ? `@${twitter}` : undefined,
      }}
      {...seoParams}
    />
    <Fragment set:html={HEADER_INJECT} />
  </head>

  <body class:list={[showBanner && 'has-announcement']}>
    {
      showBanner ? (
        <div class="announcement-bar" role="region" aria-label="站点公告">
          <p class="sr-only">{bannerText}</p>
          <div class="announcement-track" aria-hidden="true">
            <span>&#x26A0;&#xFE0F; {bannerText}</span>
            <span>&#x26A0;&#xFE0F; {bannerText}</span>
            <span>&#x26A0;&#xFE0F; {bannerText}</span>
            <span>&#x26A0;&#xFE0F; {bannerText}</span>
          </div>
        </div>
      ) : null
    }
    <a href="#main-content" class={skipLinkClass}>{skipLinkText}</a>
    <header class={topNavWrapClass} aria-label="站点导航">
      <div class={topNavClass}>
        <a href={SITE_URL} title={channel?.title} class={topNavBrandClass}>
          <img
            src={avatarUrl ?? voidFile.src}
            alt=""
            loading="eager"
            fetchpriority="high"
            width="28"
            height="28"
            class={topNavLogoClass}
          />
          <span class={topNavBrandTextClass} style={siteTitleStyle}>{channel?.title}</span>
        </a>
        <div class={topNavGroupClass}>
          <nav aria-label="Primary navigation">
            <ul class={navListClass}>
              <li class={navItemClass}>
                <a
                  href={SITE_URL}
                  title={channel?.title}
                  class:list={[navLinkClass, currentPathname === siteRootPathname && navLinkCurrentClass]}
                >
                  主页
                </a>
              </li>
              {
                TAGS ? (
                  <li class={navItemClass}>
                    <a
                      href={`${SITE_URL}tags`}
                      title="Tags"
                      class:list={[navLinkClass, currentPathname === tagsPathname && navLinkCurrentClass]}
                    >
                      Tags
                    </a>
                  </li>
                ) : null
              }
              {
                LINKS ? (
                  <li class={navItemClass}>
                    <a
                      href={`${SITE_URL}links`}
                      title="Links"
                      class:list={[navLinkClass, currentPathname === linksPathname && navLinkCurrentClass]}
                    >
                      Links
                    </a>
                  </li>
                ) : null
              }
              {
                navs.map((nav) => (
                  <li class={navItemClass}>
                    <a href={nav.href} title={nav.title} target="_blank" rel="noopener noreferrer" class={navLinkClass}>
                      {nav.title}
                    </a>
                  </li>
                ))
              }
            </ul>
          </nav>
        </div>
        <div class={topNavActionClass}>
          <nav class={socialNavClass} aria-label="Channel links">
            {
              socialLinks.map((item) => (
                <a
                  href={item.href}
                  title={item.title}
                  target="_blank"
                  rel={item.rel}
                  type={item.type}
                  aria-label={item.label}
                  class={socialLinkClass}
                >
                  <Icon name={item.icon} class={socialIconClass} aria-hidden="true" />
                </a>
              ))
            }
          </nav>
          <form class={searchFormClass} action={searchAction} method="get" role="search">
            {GOOGLE_SEARCH_SITE ? <input type="hidden" name="as_sitesearch" value={GOOGLE_SEARCH_SITE} /> : null}
            <label class="sr-only" for="search-query">{searchLabelText}</label>
            <input
              id="search-query"
              class={searchInputClass}
              type="search"
              name="q"
              placeholder="Search"
              autocomplete="off"
              inputmode="search"
              spellcheck={false}
            />
          </form>
          <footer class={footerClass}>
            <a
              href="https://blog.88lin.eu.org"
              title="茉灵智库"
              target="_blank"
              rel="noopener noreferrer"
              class={footerLinkClass}
            >
              茉灵智库
            </a>
          </footer>
        </div>
      </div>
    </header>
    <main id="main-content" class={layoutShellClass}>
      <div class={layoutGridClass}>
        <div class={mainPanelClass}>
          <slot />
        </div>
      </div>
    </main>
    <div id="back-to-top-wrapper">
      <a href="#main-content" id="back-to-top" class={backToTopClass} aria-label="Back to top">
        <img {...backToTopIcon} class={backToTopIconClass} alt="" />
      </a>
    </div>
    <script is:inline>
      ;(() => {
        const storageKey = 'broadcast-channel:read-posts:v1'
        const visibleDelay = 260
        const memoryStore = new Set()
        const state = (window.__broadcastReadState ||= {
          cards: [],
          timers: new Map(),
          bound: false,
          scheduled: false,
        })

        function readStore() {
          const storedValue = localStorage.getItem(storageKey)
          if (!storedValue) {
            return new Set(memoryStore)
          }

          return new Set(storedValue.split('\n').filter(Boolean))
        }

        function writeStore(store) {
          memoryStore.clear()
          store.forEach((postId) => memoryStore.add(postId))
          localStorage.setItem(storageKey, Array.from(store).join('\n'))
        }

        function markRead(card, store) {
          const postId = card.dataset.postId
          if (!postId) {
            return
          }

          if (!store.has(postId)) {
            store.add(postId)
            writeStore(store)
          }

          card.dataset.readState = 'read'
        }

        function initReadStates() {
          const cards = Array.from(document.querySelectorAll('[data-read-post][data-post-id]'))
          if (!cards.length) {
            return
          }

          const store = readStore()

          state.timers.forEach((timer) => window.clearTimeout(timer))
          state.timers.clear()
          state.cards = cards

          cards.forEach((card) => {
            card.dataset.readState = store.has(card.dataset.postId) ? 'read' : 'unread'
          })

          checkVisibleCards(store)
        }

        function checkVisibleCards(store = readStore()) {
          const viewportHeight = window.innerHeight || document.documentElement.clientHeight
          const readLine = Math.max(120, viewportHeight * 0.42)

          state.cards.forEach((card) => {
            if (card.dataset.readState === 'read') {
              return
            }

            const rect = card.getBoundingClientRect()
            const isPastReadLine = rect.top <= readLine && rect.bottom >= 0

            if (!isPastReadLine) {
              const timer = state.timers.get(card)
              if (timer) {
                window.clearTimeout(timer)
                state.timers.delete(card)
              }
              return
            }

            if (state.timers.has(card)) {
              return
            }

            const timer = window.setTimeout(() => {
              markRead(card, store)
              state.timers.delete(card)
            }, visibleDelay)

            state.timers.set(card, timer)
          })
        }

        function scheduleVisibleCheck() {
          if (state.scheduled) {
            return
          }

          state.scheduled = true
          window.requestAnimationFrame(() => {
            state.scheduled = false
            checkVisibleCards()
          })
        }

        if (!state.bound) {
          document.addEventListener('DOMContentLoaded', initReadStates, { once: true })
          document.addEventListener('astro:page-load', initReadStates)
          window.addEventListener('scroll', scheduleVisibleCheck, { passive: true })
          window.addEventListener('resize', scheduleVisibleCheck)
          state.bound = true
        }

        initReadStates()
      })()
    </script>
    <Fragment set:html={FOOTER_INJECT} />
  </body>
</html>
