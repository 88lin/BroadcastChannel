---
import List from '../../components/list.astro'
import { getTimelinePage, isRootTimelineCursor } from '../../lib/telegram'
import type { SeoMeta } from '../../types'

if (!Astro.params.cursor) {
  return Astro.redirect('/')
}

try {
  if (isRootTimelineCursor(Astro.params.cursor)) {
    return Astro.redirect('/')
  }
} catch {
  return Astro.redirect('/')
}

let channel

try {
  ;({ channel } = await getTimelinePage(Astro, Astro.params.cursor))
} catch {
  return Astro.redirect('/')
}

const pageSeo: SeoMeta = {
  noindex: true,
}
---

<List channel={channel} pageHeading={channel.title} pageSeo={pageSeo} />
