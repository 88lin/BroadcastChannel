---
import ChannelAvatar from '../../components/ChannelAvatar.astro'
import List from '../../components/list.astro'
import { siteTitleClass } from '../../lib/style-classes'
import { getChannelPost, getChannelSummary } from '../../lib/telegram'

const { SITE_URL } = Astro.locals
const channelInfo = await getChannelSummary(Astro)

if (!Astro.params.id) {
  return Astro.redirect('/')
}

const post = await getChannelPost(Astro, Astro.params.id)
const channel = {
  ...(channelInfo || {}),
  posts: post ? [post] : [],
}
const notFoundSeo = {
  title: 'Post Not Found',
  text: 'The requested post could not be found.',
  noindex: true,
}

if (!post) {
  Astro.response.status = 404
}

const breadcrumbClass = 'mb-5 py-[10px] font-semibold'
const breadcrumbListClass = 'm-0 flex list-none items-center p-0'
const breadcrumbLinkClass = 'inline-flex items-center no-underline'
const breadcrumbAvatarClass = 'block h-5 w-5 rounded-full border-2 border-white object-cover shadow-soft'
const breadcrumbTitleClass = `ml-[10px] flex-1 text-[14px] text-heading ${siteTitleClass}`
const notFoundMessageClass =
  'ml-[3px] border-l-2 border-line py-[30px] pl-[15px] text-base leading-[1.6] text-muted sm:pl-[30px]'
---

{
  !post ? (
    <List
      channel={channel}
      before={false}
      after={false}
      isItem={true}
      pageHeading="Post Not Found"
      pageSeo={notFoundSeo}
    >
      <div class={notFoundMessageClass}>The requested post could not be found.</div>
    </List>
  ) : (
    <List
      channel={channel}
      before={false}
      after={false}
      isItem={true}
      pageHeading={post.title || channel.title}
      pageSeo={post}
    >
      <nav slot="header" class={breadcrumbClass} aria-label="Breadcrumb">
        <ol class={breadcrumbListClass}>
          <li>
            <a href={SITE_URL} class={breadcrumbLinkClass} title={channel?.title}>
              <ChannelAvatar
                channel={channel}
                alt={channel?.title}
                loading="eager"
                width="20"
                height="20"
                class={breadcrumbAvatarClass}
              />
              <span class={breadcrumbTitleClass}>{channel.title}</span>
            </a>
          </li>
        </ol>
      </nav>
    </List>
  )
}
