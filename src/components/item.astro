---
import { getBooleanEnv, getStringEnv, parseCsvList } from '../lib/env'
import { formatPostTime, getReactionLabel, getTagHref } from '../lib/post-ui'
import { sanitizeContentHtml } from '../lib/sanitize'

const locale = getStringEnv(import.meta.env, Astro, 'LOCALE')
const timezone = getStringEnv(import.meta.env, Astro, 'TIMEZONE')

const { SITE_URL } = Astro.locals
const { post, isItem } = Astro.props

const channels = parseCsvList(getStringEnv(import.meta.env, Astro, 'CHANNEL'))
const isMultiChannel = channels.length > 1
const commentsEnabled = getBooleanEnv(import.meta.env, Astro, 'COMMENTS')
const reactionsEnabled = getBooleanEnv(import.meta.env, Astro, 'REACTIONS')

let discussionChannel = channels[0]
let discussionId = post.id

if (isMultiChannel && post.id.includes('-')) {
  const parts = post.id.split('-')
  discussionChannel = parts[0]
  discussionId = parts.slice(1).join('-')
}

const timeago = formatPostTime(post.datetime, timezone, locale)
const contentHtml = sanitizeContentHtml(post.content)
const hasContent = contentHtml.length > 0
const hasReactions = Boolean(reactionsEnabled && post.reactions?.length > 0)
const hasTags = post.tags.length > 0
const articleClass =
  'w-full min-w-0 max-w-full rounded-3xl border border-line bg-surface px-5 py-5 shadow-craft transition duration-200 sm:px-7 sm:py-7 lg:px-8 lg:py-8 lg:hover:shadow-soft'
const timeBoxClass = 'flex items-center leading-none'
const timeDotClass = 'read-state-dot h-[8px] w-[8px] rounded-full bg-muted/45'
const timeTextClass = 'm-0 flex-1 pl-[10px] text-[14px] font-medium text-muted'
const itemLinkClass = 'text-muted no-underline hover:text-heading hover:underline'
const contentClass = 'mt-5'
const reactionBoxClass = 'mt-5 border-t border-line pt-4'
const reactionListClass = 'm-0 flex list-none flex-wrap gap-[6px] p-0'
const reactionPillClass =
  'inline-flex items-center gap-1 rounded-full border border-line bg-[#f3f4f6] py-[3px] pl-[6px] pr-[8px] text-[12px] text-muted'
const reactionPaidClass = 'border-[#facc15] bg-[#fbf3db] text-heading'
const reactionEmojiClass = 'inline-flex items-center text-[14px] leading-none'
const reactionCountClass = 'font-medium opacity-80 [font-variant-numeric:tabular-nums]'
const tagBoxClass = 'mt-5 flex flex-wrap items-center gap-2 border-t border-line pt-4 text-[14px] leading-[1.6]'
const tagPaddingClass = commentsEnabled && isItem ? 'mb-5' : ''
const tagStandaloneClass = 'mt-5'
const tagLinkClass =
  'inline-flex items-center rounded-2xl border border-transparent bg-transparent px-3 py-1 text-[13px] font-medium text-muted no-underline transition hover:border-[#93c5fd] hover:bg-[#ebf4ff] hover:text-heading hover:shadow-[0_6px_12px_rgba(59,130,246,0.08)] hover:no-underline'
const commentsClass = 'tg-comments mt-5 border-t border-line pt-4'
---

<article
  class={articleClass}
  data-read-post
  data-post-id={post.id}
  data-read-state="unknown"
  style={{ 'view-transition-name': `post-${post.id}` }}
>
  <header class={timeBoxClass}>
    <span class={timeDotClass} aria-hidden="true"></span>
    <p class={timeTextClass}>
      <a href={`${SITE_URL}posts/${post.id}`} title={post.datetime} class={itemLinkClass}>
        <time datetime={post.datetime} title={timeago}>{timeago}</time>
      </a>
    </p>
  </header>
  {hasContent && <div class:list={[contentClass, 'content']} set:html={contentHtml} />}
  {
    hasReactions && (
      <div class:list={[reactionBoxClass, hasContent && '-mt-3 pt-0']}>
        <ul class={reactionListClass} role="list" aria-label="Reactions">
          {post.reactions.map((reaction) => (
            <li
              class:list={[reactionPillClass, reaction.isPaid && reactionPaidClass]}
              aria-label={getReactionLabel(reaction)}
            >
              <span class={reactionEmojiClass}>
                {reaction.isPaid ? (
                  '\u2B50'
                ) : reaction.emojiImage ? (
                  <img
                    src={reaction.emojiImage}
                    alt={reaction.emoji || 'emoji'}
                    loading="lazy"
                    width="20"
                    height="20"
                    class="block h-[1em] w-[1em]"
                  />
                ) : (
                  reaction.emoji
                )}
              </span>
              <span class={reactionCountClass}>{reaction.count}</span>
            </li>
          ))}
        </ul>
      </div>
    )
  }
  {
    hasTags && (
      <footer class:list={[tagBoxClass, tagPaddingClass, !hasContent && tagStandaloneClass]}>
        <span class="tag-icon" aria-hidden="true" />
        {post.tags.map((tag: string) => (
          <a href={getTagHref(tag)} title={tag} class={tagLinkClass}>
            {tag}
          </a>
        ))}
      </footer>
    )
  }

  {
    commentsEnabled && isItem && discussionChannel && (
      <section class={commentsClass} aria-label="Comments">
        {/* Telegram comments are the only intentional client-side JS exception. */}
        <script
          is:inline
          async
          src="https://telegram.org/js/telegram-widget.js"
          data-telegram-discussion={`${discussionChannel}/${discussionId}`}
          data-comments-limit="50"
          data-colorful="1"
          data-color="454545"
        />
      </section>
    )
  }
</article>
